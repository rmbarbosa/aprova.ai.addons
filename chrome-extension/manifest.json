{
  "manifest_version": 3,
  "name": "Aprova.ai Extension",
  "version": "1.0.0",
  "description": "Preenchimento inteligente de formulários de candidatura — powered by Claude",
  "author": "Rui Barbosa @rmblda 2026",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "debugger",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:9090/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
